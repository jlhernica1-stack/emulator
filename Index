let selectedSystem = null;
let romFile = null;

function buildCategories() {
  const container = document.getElementById('all-categories');
  let total = 0;
  CATEGORIES.forEach(cat => {
    total += cat.systems.length;
    const section = document.createElement('div');
    section.className = 'cat-section';
    section.innerHTML = `
      <div class="cat-header">
        <span class="cat-icon">${cat.icon}</span>
        <div>
          <div class="cat-title">${cat.title}</div>
          <div class="cat-desc">${cat.desc}</div>
        </div>
      </div>
      <div class="systems-grid" id="grid-${cat.title.replace(/\s/g,'')}"></div>
    `;
    container.appendChild(section);
    const grid = section.querySelector('.systems-grid');
    cat.systems.forEach(sys => {
      const card = document.createElement('div');
      card.className = 'system-card';
      const badgeClass = sys.status === 'beta' ? 'badge-beta' : 'badge-stable';
      const badgeText = sys.status === 'beta' ? '⚠ BETA' : '✓ ESTABLE';
      card.innerHTML = `
        <span class="system-icon">${sys.icon}</span>
        <div class="system-name">${sys.name}</div>
        <div class="system-badge ${badgeClass}">${badgeText}</div>
      `;
      card.onclick = () => selectSystem(sys, card);
      grid.appendChild(card);
    });
  });
  document.getElementById('system-count').textContent = `${total} SISTEMAS DISPONIBLES`;
}

function buildSystemsTable() {
  const tbody = document.getElementById('systems-table-body');
  CATEGORIES.forEach(cat => {
    const catRow = document.createElement('tr');
    catRow.innerHTML = `<td colspan="4" style="padding:10px 8px 4px;color:#ff0055;font-family:'Press Start 2P',monospace;font-size:7px;border-top:1px solid #1a1a1a">${cat.icon} ${cat.title}</td>`;
    tbody.appendChild(catRow);
    cat.systems.forEach(sys => {
      const tr = document.createElement('tr');
      const badge = sys.status === 'beta'
        ? '<span class="tbl-badge tbl-yellow">BETA</span>'
        : '<span class="tbl-badge tbl-green">ESTABLE</span>';
      tr.innerHTML = `
        <td>${sys.icon} ${sys.name}</td>
        <td><code style="background:#111;padding:1px 4px;color:#0f0;font-size:9px">${sys.core}</code></td>
        <td style="font-size:9px;color:#555">${sys.exts}</td>
        <td>${badge}</td>
      `;
      tbody.appendChild(tr);
    });
  });
}

function selectSystem(sys, card) {
  document.querySelectorAll('.system-card').forEach(c => c.classList.remove('selected'));
  card.classList.add('selected');
  selectedSystem = sys;
  document.getElementById('sel-name').textContent = sys.name;
  document.getElementById('sel-core').textContent = sys.core;
  document.getElementById('sel-exts').textContent = sys.exts;
  document.getElementById('selected-info').classList.add('visible');
  checkLaunchReady();
  document.getElementById('launch-area').scrollIntoView({behavior:'smooth',block:'nearest'});
}

function handleRom(input) {
  if (input.files && input.files[0]) {
    romFile = input.files[0];
    document.getElementById('rom-filename').textContent = '✓ ' + romFile.name;
    checkLaunchReady();
  }
}

const dropZone = document.getElementById('rom-drop');
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('dragover'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('dragover');
  if (e.dataTransfer.files && e.dataTransfer.files[0]) {
    romFile = e.dataTransfer.files[0];
    document.getElementById('rom-filename').textContent = '✓ ' + romFile.name;
    checkLaunchReady();
  }
});

function checkLaunchReady() {
  document.getElementById('launch-btn').disabled = !(selectedSystem && romFile);
}

function launchGame() {
  if (!selectedSystem || !romFile) return;
  const romUrl = URL.createObjectURL(romFile);
  const gameName = romFile.name.replace(/\.[^.]+$/, '');
  document.getElementById('emu-title').textContent = `▶ ${gameName} · ${selectedSystem.name}`;
  const emuHTML = `<!DOCTYPE html>
<html><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<title>${gameName}</title>
<style>*{margin:0;padding:0;box-sizing:border-box}body{background:#000;display:flex;align-items:center;justify-content:center;width:100vw;height:100vh;overflow:hidden}#game{width:100%;height:100%}</style>
</head><body>
<div id="game"></div>
<script>
var EJS_player="#game";
var EJS_core="${selectedSystem.core}";
var EJS_gameUrl="${romUrl}";
var EJS_pathtodata="https://cdn.emulatorjs.org/stable/data/";
var EJS_startOnLoaded=true;
var EJS_color="#ff0055";
var EJS_language="es";
var EJS_Buttons={playPause:true,restart:true,mute:true,settings:true,fullscreen:true,saveState:true,loadState:true,screenRecord:false,gamepad:true,cheat:false,volume:true,saveSavFiles:true,loadSavFiles:true,quickSave:true,quickLoad:true};
<\/script>
<script src="https://cdn.emulatorjs.org/stable/data/loader.js"><\/script>
</body></html>`;
  const blob = new Blob([emuHTML], {type:'text/html'});
  const container = document.getElementById('emu-container');
  container.innerHTML = '';
  const iframe = document.createElement('iframe');
  iframe.src = URL.createObjectURL(blob);
  iframe.setAttribute('allowfullscreen','');
  iframe.setAttribute('allow','gamepad; fullscreen; autoplay');
  iframe.style.cssText = 'width:100%;height:100%;border:none';
  container.appendChild(iframe);
  document.getElementById('emu-screen').classList.add('active');
  document.body.style.overflow = 'hidden';
}

function closeEmulator() {
  document.getElementById('emu-screen').classList.remove('active');
  document.getElementById('emu-container').innerHTML = '';
  document.body.style.overflow = '';
}

function showSection(name, tabEl) {
  ['launcher','controls','systems','setup'].forEach(s => {
    document.getElementById('section-'+s).style.display = 'none';
  });
  document.getElementById('section-'+name).style.display = 'block';
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  tabEl.classList.add('active');
}

buildCategories();
buildSystemsTable();
</script>
</body>
</html>
