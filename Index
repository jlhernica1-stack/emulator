<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>⚡ RetroLauncher Pro</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Share+Tech+Mono&display=swap');

*{box-sizing:border-box;margin:0;padding:0}
body{background:#07070d;color:#ddd;font-family:'Share Tech Mono',monospace;min-height:100vh}

.scanline{position:fixed;top:0;left:0;width:100%;height:100%;
  background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.07) 2px,rgba(0,0,0,0.07) 4px);
  pointer-events:none;z-index:9999}

header{text-align:center;padding:2rem 1rem 1.2rem;border-bottom:2px solid #ff0055;position:relative;overflow:hidden}
header::before{content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 50% 0%,rgba(255,0,85,0.08) 0%,transparent 70%);pointer-events:none}
header h1{font-family:'Press Start 2P',monospace;font-size:clamp(12px,3vw,20px);color:#ff0055;
  text-shadow:0 0 12px #ff0055,0 0 24px #ff003366;letter-spacing:2px;animation:flicker 5s infinite}
header p{margin-top:.5rem;font-size:10px;color:#666;letter-spacing:1px}
.system-count{display:inline-block;margin-top:.4rem;padding:3px 10px;border:1px solid #ff005544;
  color:#ff005599;font-size:9px;font-family:'Press Start 2P',monospace}

@keyframes flicker{0%,100%{opacity:1}91%{opacity:1}92%{opacity:.7}93%{opacity:1}97%{opacity:.85}98%{opacity:1}}

nav{display:flex;justify-content:center;flex-wrap:wrap;gap:6px;padding:.8rem 1rem;
  border-bottom:1px solid #1a1a1a;background:#09090f;position:sticky;top:0;z-index:100}
.tab{font-family:'Press Start 2P',monospace;font-size:7px;padding:7px 10px;background:transparent;
  border:1px solid #252525;color:#444;cursor:pointer;transition:all .15s;letter-spacing:.5px;white-space:nowrap}
.tab:hover{border-color:#ff0055;color:#ff0055}
.tab.active{border-color:#ff0055;color:#ff0055;background:#ff005512}

.main{padding:1.5rem 1rem;max-width:1000px;margin:0 auto}

.cat-section{margin-bottom:2.5rem}
.cat-header{display:flex;align-items:center;gap:12px;margin-bottom:1rem;padding-bottom:.5rem;
  border-bottom:1px solid #1a1a1a}
.cat-icon{font-size:20px}
.cat-title{font-family:'Press Start 2P',monospace;font-size:9px;color:#ff0055;letter-spacing:1px}
.cat-desc{font-size:10px;color:#444;margin-top:2px}

.systems-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px}
.system-card{background:#0f0f18;border:1px solid #1c1c2a;padding:14px 10px;cursor:pointer;
  transition:all .2s;text-align:center;position:relative;overflow:hidden}
.system-card::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;
  background:linear-gradient(90deg,transparent,rgba(255,0,85,0.06),transparent);transition:left .4s}
.system-card:hover::before{left:100%}
.system-card:hover{border-color:#ff005577;transform:translateY(-2px)}
.system-card.selected{border-color:#ff0055;background:#1a0008;box-shadow:0 0 12px #ff005522}

.system-icon{font-size:24px;margin-bottom:6px;display:block}
.system-name{font-family:'Press Start 2P',monospace;font-size:6px;color:#bbb;line-height:1.7;letter-spacing:.3px}
.system-badge{display:inline-block;margin-top:4px;padding:1px 5px;font-size:7px;border-radius:1px}
.badge-stable{background:#0a200a;color:#0f0;border:1px solid #0f0}
.badge-beta{background:#1a1a00;color:#ff0;border:1px solid #ff0}

.launch-area{background:#0c0c18;border:1px solid #1c1c2a;padding:1.5rem;margin-bottom:1.5rem}
.launch-area h2{font-family:'Press Start 2P',monospace;font-size:9px;color:#ff0055;margin-bottom:1rem;letter-spacing:1px}

.selected-info{background:#0f0f1f;border:1px solid #252540;padding:10px 14px;margin-bottom:1rem;
  display:none;font-size:11px;color:#888}
.selected-info.visible{display:block}
.selected-info strong{color:#ff0055;font-size:10px}

.rom-drop{border:2px dashed #252525;padding:1.8rem 1rem;text-align:center;cursor:pointer;
  transition:all .2s;position:relative}
.rom-drop:hover,.rom-drop.dragover{border-color:#ff0055;background:#ff005508}
.rom-drop input[type=file]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.rom-drop-icon{font-size:28px;margin-bottom:6px}
.rom-drop p{font-size:10px;color:#555}
.rom-drop p span{color:#ff0055}
.rom-filename{margin-top:6px;font-size:11px;color:#0f0}

.launch-btn{display:block;width:100%;margin-top:1rem;padding:13px;
  font-family:'Press Start 2P',monospace;font-size:9px;background:#ff0055;
  color:#fff;border:none;cursor:pointer;letter-spacing:2px;transition:all .15s}
.launch-btn:hover{background:#ff3377;transform:scale(1.005)}
.launch-btn:active{transform:scale(.998)}
.launch-btn:disabled{background:#1a1a1a;color:#333;cursor:not-allowed;transform:none}

#emu-screen{display:none;position:fixed;inset:0;background:#000;z-index:2000;flex-direction:column}
#emu-screen.active{display:flex}
.emu-topbar{display:flex;justify-content:space-between;align-items:center;padding:7px 12px;
  background:#07070d;border-bottom:1px solid #ff0055;flex-shrink:0;gap:8px}
.emu-title{font-family:'Press Start 2P',monospace;font-size:7px;color:#ff0055;flex:1;overflow:hidden;
  white-space:nowrap;text-overflow:ellipsis}
.emu-close{font-family:'Press Start 2P',monospace;font-size:7px;padding:6px 10px;background:transparent;
  border:1px solid #ff0055;color:#ff0055;cursor:pointer;white-space:nowrap;flex-shrink:0}
.emu-close:hover{background:#ff0055;color:#fff}
#emu-container{flex:1;display:flex;align-items:center;justify-content:center;background:#000;overflow:hidden}
#emu-container iframe{width:100%;height:100%;border:none}

.notice{background:#12120a;border:1px solid #3a3a00;padding:10px 14px;margin-bottom:1.5rem;
  font-size:10px;color:#888870;line-height:1.9}
.notice strong{color:#cc0;font-family:'Press Start 2P',monospace;font-size:7px}

.controls-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:10px}
.control-card{background:#0f0f18;border:1px solid #1c1c2a;padding:1rem}
.control-card h3{font-family:'Press Start 2P',monospace;font-size:7px;color:#ff0055;margin-bottom:10px}
.control-row{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #111;font-size:10px}
.control-key{background:#1a1a1a;padding:2px 6px;border:1px solid #333;border-bottom:2px solid #444;
  border-radius:2px;color:#fff;font-size:9px}

.systems-table{width:100%;border-collapse:collapse;font-size:10px}
.systems-table th{font-family:'Press Start 2P',monospace;font-size:7px;color:#ff0055;padding:8px;
  text-align:left;border-bottom:1px solid #ff0055}
.systems-table td{padding:7px 8px;border-bottom:1px solid #111;color:#888}
.systems-table tr:hover td{background:#0f0f18}
.tbl-badge{display:inline-block;padding:2px 5px;font-size:8px;border-radius:1px}
.tbl-green{background:#0a200a;color:#0f0;border:1px solid #0f0}
.tbl-yellow{background:#1a1a00;color:#ff0;border:1px solid #ff0}

.ticker{border-top:1px solid #ff005522;padding:5px 0;margin-top:1.5rem;
  font-size:8px;color:#ff005566;overflow:hidden;white-space:nowrap}
.ticker-inner{display:inline-block;animation:ticker 30s linear infinite}
@keyframes ticker{from{transform:translateX(100vw)}to{transform:translateX(-100%)}}

@media(max-width:500px){
  .systems-grid{grid-template-columns:repeat(2,1fr)}
  .controls-grid{grid-template-columns:1fr}
  header h1{font-size:10px}
}
</style>
</head>
<body>
<div class="scanline"></div>

<div id="emu-screen">
