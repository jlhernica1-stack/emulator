<!-- GUÍA -->
<div id="section-setup" style="display:none">
  <div style="background:#0f0f18;border-left:3px solid #ff0055;padding:1rem;margin-bottom:1rem">
    <h3 style="font-family:'Press Start 2P',monospace;font-size:8px;color:#ff0055;margin-bottom:6px">1 — SERVIDOR LOCAL</h3>
    <p style="font-size:10px;color:#888;line-height:1.9">
